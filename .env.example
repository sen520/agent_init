# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_ORGANIZATION=your_org_id_here

# Anthropic Claude配置（可选）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini配置（可选）
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# LangSmith追踪（可选）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=self-optimizing-assistant

# 项目配置
PROJECT_NAME=self-optimizing-code-assistant
PROJECT_VERSION=0.2.0
DEFAULT_PROJECT_PATH=./
MAX_ITERATIONS=10
LOG_LEVEL=INFO
DEBUG=false

# 分析配置
MAX_FUNCTION_LENGTH=50
MAX_LINE_LENGTH=100
ENABLE_SECURITY_CHECKS=true
ENABLE_PERFORMANCE_CHECKS=true
ENABLE_COMPLEXITY_ANALYSIS=true
ENABLE_DUPLICATE_CODE_DETECTION=true

# 性能配置
MAX_WORKERS=4
TIMEOUT_SECONDS=300
MEMORY_LIMIT_MB=2048

# 输出配置
OUTPUT_DIR=./output
EXPORT_FORMATS=json,md,html
BACKUP_ENABLED=true
BACKUP_DIR=./backups

# 缓存配置
CACHE_ENABLED=true
CACHE_DIR=./cache
CACHE_TTL_SECONDS=3600

# 测试配置
TEST_COVERAGE_TARGET=80
TEST_TIMEOUT_SECONDS=60

# 开发配置
DEVELOPMENT_MODE=false
AUTO_RELOAD=false
PROFILING_ENABLED=false

# 安全配置
ALLOWED_FILE_EXTENSIONS=.py,.js,.ts,.java,.cpp,.go,.rs
MAX_FILE_SIZE_MB=50
SCAN_HIDDEN_FILES=false